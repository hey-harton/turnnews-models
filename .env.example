# Salin file ini menjadi .env dan isi dengan nilai yang sebenarnya.
# JANGAN pernah commit file .env ke repository.

# ─── Groq Cloud API ───────────────────────────────────────────────
# Dapatkan API Key di: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Cloudflare R2 Object Storage ────────────────────────────────
# Digunakan untuk menyimpan file model .pkl di cloud (produksi AWS Lambda)
# Dapatkan credentials di: https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_TOKEN_VALUE=your_r2_token_value_here
R2_BUCKET_NAME=your_r2_bucket_name_here
